---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

const lastUpdated = "11 July 2026";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/assets/pjpropertylogo.svg" />
    <title>Privacy Policy | PJ New Launch Private Lift</title>
    <meta
      name="description"
      content="How PJ New Launch Private Lift and Nexsgen Realty Sdn Bhd collect, use and protect your personal data in accordance with Malaysia's Personal Data Protection Act 2010."
    />
    <meta name="robots" content="noindex, follow" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:wght@400;500;600;700&family=Hanken+Grotesk:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body id="top">
    <header class="sticky top-0 z-50 bg-white/[0.94] backdrop-blur-[12px]">
      <nav
        class="max-w-wrap mx-auto px-gutter py-[22px] flex items-center justify-between gap-6"
      >
        <a href="/" class="flex items-center gap-[13px] flex-none">
          <img
            src="/assets/pjpropertylogo.svg"
            alt="PJ New Launch Private Lift"
            class="w-[42px] h-[42px] rounded-[8px] flex-none"
          />
          <span class="flex flex-col leading-none">
            <span class="font-serif text-[22px] font-semibold tracking-[0.14em]"
              >PJ NEW LAUNCH</span
            >
            <span
              class="text-[9.5px] tracking-[0.42em] text-muted font-semibold mt-1"
              >PRIVATE LIFT</span
            >
          </span>
        </a>
        <a
          href="/"
          class="text-[13px] font-semibold tracking-[0.12em] uppercase text-[#3a382f] opacity-[0.72] transition-opacity duration-200 hover:opacity-100"
          >&larr; Back to home</a
        >
      </nav>
    </header>

    <main class="max-w-wrap mx-auto px-gutter py-[clamp(56px,8vw,110px)]">
      <div class="max-w-[760px] mx-auto">
        <p
          class="text-[13px] tracking-[0.3em] uppercase text-accent font-bold mb-5"
        >
          Legal
        </p>
        <h1
          class="font-serif font-semibold text-[clamp(34px,5vw,56px)] leading-[1.08] tracking-[-0.01em] mb-4"
        >
          Privacy Policy
        </h1>
        <p class="text-[14px] text-muted mb-[clamp(36px,5vw,56px)]">
          Last updated: {lastUpdated}
        </p>

        <div
          class="flex flex-col gap-[clamp(28px,4vw,40px)] text-[15.5px] leading-[1.75] text-body"
        >
          <p>
            This Privacy Policy explains how <strong class="text-ink"
              >Nexsgen Realty Sdn Bhd</strong
            > (Registered Estate Agency, BOVAEP Reg. No. E (1) 1914) and its appointed
            representative, Chloe Tan (REN 65782), collect, use, disclose and
            protect your personal data when you enquire about the PJ New Launch
            Private Lift residences through this website. We are committed to
            handling your personal data in accordance with Malaysia's Personal
            Data Protection Act 2010 (PDPA).
          </p>

          <section>
            <h2 class="font-serif text-[24px] font-semibold text-ink mb-3">
              1. Information we collect
            </h2>
            <p class="mb-3">
              When you register your interest or contact us, we may collect the
              personal data you choose to provide, including:
            </p>
            <ul class="list-disc pl-5 flex flex-col gap-2">
              <li>Your name;</li>
              <li>Your email address;</li>
              <li>Your mobile or contact number;</li>
              <li>
                The layout or property type you are interested in, and any
                message you send us.
              </li>
            </ul>
          </section>

          <section>
            <h2 class="font-serif text-[24px] font-semibold text-ink mb-3">
              2. How we use your information
            </h2>
            <p class="mb-3">We use your personal data to:</p>
            <ul class="list-disc pl-5 flex flex-col gap-2">
              <li>
                Respond to your enquiry and provide you with pricing, floor
                plans and other information you request;
              </li>
              <li>
                Contact you (by phone, WhatsApp, email or SMS) regarding the PJ
                New Launch Private Lift development and related opportunities;
              </li>
              <li>
                Arrange viewings and follow up on your registration of interest;
              </li>
              <li>Comply with our legal and regulatory obligations.</li>
            </ul>
          </section>

          <section>
            <h2 class="font-serif text-[24px] font-semibold text-ink mb-3">
              3. Disclosure of your information
            </h2>
            <p>
              We may share your personal data with the property developer and
              its authorised sales representatives for the purpose of processing
              your enquiry. We do not sell your personal data. We may disclose
              your data where required by law or by a regulatory authority.
            </p>
          </section>

          <section>
            <h2 class="font-serif text-[24px] font-semibold text-ink mb-3">
              4. Data retention
            </h2>
            <p>
              We retain your personal data only for as long as is necessary to
              fulfil the purposes set out in this policy, or as required to meet
              legal, tax or regulatory requirements, after which it will be
              securely deleted.
            </p>
          </section>

          <section>
            <h2 class="font-serif text-[24px] font-semibold text-ink mb-3">
              5. Your rights
            </h2>
            <p>
              Under the PDPA, you have the right to access and correct your
              personal data, and to withdraw your consent to our processing of
              it. To exercise any of these rights, please contact us using the
              details below. Once consent is withdrawn, we may be unable to
              continue providing you with information about the development.
            </p>
          </section>

          <section>
            <h2 class="font-serif text-[24px] font-semibold text-ink mb-3">
              6. Contact us
            </h2>
            <p class="mb-4">
              If you have any questions about this Privacy Policy or how your
              personal data is handled, please contact:
            </p>
            <div
              class="bg-paper rounded-[8px] p-6 text-[14.5px] leading-[1.7] text-ink"
            >
              <p class="font-semibold">Chloe Tan · REN 65782</p>
              <p class="text-muted">Nexsgen Realty Sdn Bhd (BOVAEP E (1) 1914)</p>
              <p class="mt-2">
                1-1, PJ 21 Commercial Centre, Jalan SS3/39, 47300 Petaling Jaya,
                Selangor, Malaysia
              </p>
              <p class="mt-2">
                <a
                  href="tel:+60169054333"
                  class="font-medium transition-colors duration-200 hover:text-accent"
                  >+60 16-905 4333</a
                >
                &nbsp;·&nbsp;
                <a
                  href="mailto:jiaweii927@gmail.com"
                  class="font-medium transition-colors duration-200 hover:text-accent"
                  >jiaweii927@gmail.com</a
                >
              </p>
            </div>
          </section>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>
