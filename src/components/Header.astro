---

---

<header class="bg-white/[0.94] backdrop-blur-[12px]">
  <nav
    class="max-w-wrap mx-auto px-gutter md:px-0 py-[26px] flex items-center justify-between gap-6"
  >
    <a href="#top" class="flex items-center gap-[13px] flex-none">
      <img
        src="/assets/pjpropertylogo.svg"
        alt="PJ New Launch Private Lift"
        class="w-[42px] h-[42px] rounded-[8px] flex-none"
      />
      <span class="flex flex-col leading-none">
        <span class="font-serif text-[22px] font-semibold tracking-[0.14em]"
          >PJ NEW LAUNCH</span
        >
        <span
          class="text-[9.5px] tracking-[0.42em] text-muted font-semibold mt-1"
          >PRIVATE LIFT</span
        >
      </span>
    </a>
    <div
      class="hidden md:flex items-center gap-[clamp(20px,3vw,44px)] text-[13px] font-semibold tracking-[0.14em] uppercase text-[#3a382f]"
    >
      <a
        href="#signature"
        class="opacity-[0.72] transition-opacity duration-200 hover:opacity-100"
        >Private Lift</a
      >
      <a
        href="#residences"
        class="opacity-[0.72] transition-opacity duration-200 hover:opacity-100"
        >24 feet living hall</a
      >
      <a
        href="#location"
        class="opacity-[0.72] transition-opacity duration-200 hover:opacity-100"
        >Sky Semi-D</a
      >
      <a
        href="#register"
        class="border border-ink px-[26px] py-3 rounded-[40px] tracking-[0.12em] transition-colors duration-[250ms] hover:bg-ink hover:text-white"
        >Register Interest</a
      >
    </div>
  </nav>
</header>
