---

---

<section id="signature" class="py-[clamp(60px,8vw,120px)] px-gutter">
  <div class="max-w-wrap mx-auto">
    <div
      class="grid grid-cols-[repeat(auto-fit,minmax(320px,1fr))] gap-[clamp(44px,6vw,100px)] items-center"
    >
      <div class="relative rounded-[6px] overflow-hidden">
        <img
          class="w-full h-auto"
          src="/assets/private-lift-2.jpeg"
          alt="Private foyer opening directly into the home entrance"
        />
        <span
          class="absolute bottom-4 left-[18px] text-[11px] tracking-[0.18em] uppercase text-white/90 font-medium [text-shadow:0_1px_6px_rgba(0,0,0,0.6)]"
          >Direct-to-home foyer · Artist's Impression</span
        >
      </div>
      <div>
        <p
          class="text-[13px] tracking-[0.3em] uppercase text-muted font-semibold mb-[clamp(24px,3vw,40px)]"
        >
          privacy
        </p>
        <h2
          class="font-serif font-semibold text-[clamp(26px,3.2vw,42px)] leading-[1.15] tracking-[-0.008em] mb-[clamp(24px,3vw,36px)]"
        >
          <span class="text-accent">Private Lift</span>, for every home.
        </h2>
        <p
          class="text-[clamp(15.5px,1.5vw,17.5px)] leading-[1.74] text-body font-light max-w-[48ch]"
        >
          Private access and discreet arrival, where every return feels
          personal. A private foyer separates your home from the service lobby —
          no shared corridors, no crowded landings. Every coming and going stays
          entirely your own.
        </p>
        <p
          class="text-[clamp(15.5px,1.5vw,17.5px)] leading-[1.74] text-body font-light max-w-[48ch] mt-5"
        >
          Your lift opens directly onto a foyer that is yours alone — 2m wide
          for Types A &amp; B, 1.8m for Type C — with generous room for a shoe
          cabinet, pedestal and seating. A landed sense of arrival, elevated
          into the sky.
        </p>
        <a
          href="#residences"
          class="inline-flex items-center gap-2.5 text-[13px] font-semibold tracking-[0.14em] uppercase text-ink border-b border-accent pb-1.5 transition-colors duration-200 hover:text-accent mt-[clamp(28px,3vw,40px)]"
        >
          Explore Residences
          <svg
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg
          >
        </a>
      </div>
    </div>
  </div>
</section>
