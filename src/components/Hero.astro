---
const slides = [
  'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?auto=format&fit=crop&w=1900&q=72',
  'https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=1900&q=72',
  'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1900&q=72',
];
---

<section class="pt-[clamp(70px,9vw,140px)] px-gutter">
  <div class="max-w-wrap mx-auto">
    <p class="text-[12.5px] tracking-[0.3em] uppercase text-accent font-bold mb-[clamp(28px,3vw,44px)]">Something exclusive is coming · Petaling Jaya</p>
    <div class="flex flex-wrap gap-[clamp(32px,6vw,90px)] items-start justify-between mt-[clamp(36px,4vw,56px)]">
      <h1 class="flex-[1_1_320px] font-serif font-semibold text-[clamp(34px,4.6vw,58px)] leading-[1.08] tracking-[-0.01em] max-w-[14ch] [text-wrap:balance]">When arrival becomes an <span class="text-accent">experience.</span></h1>
      <div class="flex-[1_1_380px] flex flex-col items-start gap-[clamp(24px,3vw,34px)]">
        <p class="text-[clamp(17px,1.8vw,21px)] leading-[1.62] max-w-[46ch] text-body font-light">
          A limited, low-density collection of luxury residences in the heart of Petaling Jaya —
          where every home opens to its own private lift lobby.
        </p>
        <div class="flex flex-wrap gap-3.5">
          <a href="#register" class="inline-block px-9 py-[18px] rounded-[40px] text-[13px] font-semibold tracking-[0.14em] uppercase transition-colors duration-[250ms] bg-accent text-white hover:bg-accent-hover">Register Your Interest</a>
          <a href="#residences" class="inline-block px-9 py-[18px] rounded-[40px] text-[13px] font-semibold tracking-[0.14em] uppercase transition-colors duration-[250ms] border border-[rgba(42,40,32,0.3)] text-ink hover:border-ink">Explore Residences</a>
        </div>
      </div>
    </div>
  </div>
  <div class="max-w-wrap mx-auto mt-[clamp(48px,6vw,88px)] relative rounded-[6px] overflow-hidden h-[clamp(380px,58vh,680px)] bg-[#1a201a]" id="hero-media">
    {
      slides.map((src, i) => (
        <div
          data-slide
          class:list={[
            'absolute inset-0 bg-center bg-cover bg-no-repeat transition-opacity duration-[1600ms] ease-linear',
            i === 0 ? 'opacity-100' : 'opacity-0',
          ]}
          style={`background-image:url('${src}')`}
        />
      ))
    }
    <span class="absolute bottom-[18px] right-5 text-[11px] tracking-[0.22em] uppercase text-white/85 font-medium border border-white/40 px-[13px] py-1.5 rounded-[2px] backdrop-blur-[3px]">Artist's Impression</span>
  </div>
</section>

<script>
  const media = document.getElementById('hero-media');
  if (media) {
    const slides = Array.from(media.querySelectorAll<HTMLElement>('[data-slide]'));
    if (slides.length > 1) {
      let index = 0;
      setInterval(() => {
        slides[index].classList.replace('opacity-100', 'opacity-0');
        index = (index + 1) % slides.length;
        slides[index].classList.replace('opacity-0', 'opacity-100');
      }, 5000);
    }
  }
</script>
