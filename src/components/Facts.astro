---
const facts = [
  { num: '3', label: 'Exclusive layouts' },
  { num: '1,165–1,880', label: 'Built-up (sqft)', size: 'text-[clamp(22px,2.4vw,32px)]' },
  { num: '3–4', label: 'Bedrooms' },
  { num: 'Up to 3', label: 'Carparks' },
];
---

<section class="py-[clamp(64px,8vw,110px)] px-gutter">
  <div class="max-w-wrap mx-auto border-t border-b border-line py-[clamp(40px,5vw,64px)] grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-[clamp(28px,4vw,48px)]">
    {
      facts.map((fact) => (
        <div>
          <div class:list={['font-serif font-medium leading-none whitespace-nowrap', fact.size ?? 'text-[clamp(32px,3.6vw,46px)]']}>{fact.num}</div>
          <div class="text-[13.5px] tracking-[0.06em] text-muted-2 mt-3">{fact.label}</div>
        </div>
      ))
    }
  </div>
</section>
