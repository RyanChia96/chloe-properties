<section id="living-hall" class="py-[clamp(60px,8vw,120px)] px-gutter">
  <div class="max-w-wrap mx-auto grid grid-cols-[repeat(auto-fit,minmax(320px,1fr))] gap-[clamp(44px,6vw,100px)] items-center">
    <div>
      <p class="text-[13px] tracking-[0.3em] uppercase text-muted font-semibold mb-[clamp(24px,3vw,40px)]">space</p>
      <h2 class="font-serif font-semibold text-[clamp(26px,3.2vw,42px)] leading-[1.15] tracking-[-0.008em]">
        A <span class="text-accent">24-foot</span> living hall, wall to wall.
      </h2>
      <p class="text-[clamp(15.5px,1.5vw,17.5px)] leading-[1.74] text-body font-light max-w-[46ch] mt-[clamp(24px,3vw,36px)]">
        No bulkheads breaking the span, no beams cutting the room in half —
        just one uninterrupted 24-foot hall that takes a full dining set and a
        proper lounge without either feeling squeezed.
      </p>
      <p class="text-[clamp(15.5px,1.5vw,17.5px)] leading-[1.74] text-body font-light max-w-[46ch] mt-5">
        Floor-to-ceiling glazing runs the full width, so daylight reaches
        every corner of the hall rather than fading past the first few feet —
        a living space that entertains as easily as it unwinds.
      </p>
      <a href="#residences" class="inline-flex items-center gap-2.5 text-[13px] font-semibold tracking-[0.14em] uppercase text-ink border-b border-accent pb-1.5 transition-colors duration-200 hover:text-accent mt-[clamp(28px,3vw,40px)]">
        View Layouts
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M13 6l6 6-6 6"></path></svg>
      </a>
    </div>
    <div class="relative rounded-[6px] overflow-hidden">
      <img class="w-full h-auto" src="/assets/living-hall.webp" alt="Spacious 24-foot living hall with floor-to-ceiling windows" />
      <span class="absolute bottom-4 left-[18px] text-[11px] tracking-[0.18em] uppercase text-white/90 font-medium [text-shadow:0_1px_6px_rgba(0,0,0,0.6)]">Artist's Impression</span>
    </div>
  </div>
</section>
